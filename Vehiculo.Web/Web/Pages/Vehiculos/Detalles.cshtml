@page "{id:guid}"
@model Web.Pages.Vehiculos.DetalleModel
@{
    ViewData["Title"] = "Detalle del Vehículo";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #0b0c0e;
            --surface: #111316;
            --surface2: #1a1d22;
            --border: #2a2d35;
            --accent: #e8ff47;
            --accent-dim: rgba(232, 255, 71, 0.10);
            --accent-glow: rgba(232, 255, 71, 0.22);
            --text: #f0f2f5;
            --text-muted: #6b7280;
            --text-dim: #9ca3af;
            --info: #38bdf8;
            --info-dim: rgba(56, 189, 248, 0.10);
            --edit: #a78bfa;
            --danger: #ff4d4d;
            --danger-dim: rgba(255, 77, 77, 0.10);
            --radius: 12px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Mono', monospace;
            min-height: 100vh;
        }

        /* ── Header ── */
        .page-header {
            border-bottom: 1px solid var(--border);
            padding: 28px 48px;
            display: flex;
            align-items: center;
            gap: 20px
            ;
            position: sticky;
            top: 0;
            background: rgba(11, 12, 14, 0.92);
            backdrop-filter: blur(12px);
            z-index: 100;
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 12px;
            letter-spacing: 0.06em;
            padding: 8px 14px;
            border: 1px solid var(--border);
            border-radius: 8px;
            transition: color 0.15s, border-color 0.15s, background 0.15s;
            white-space: nowrap;
        }

        .back-btn:hover {
            color: var(--text);
            border-color: var(--text-muted);
            background: var(--surface2);
        }

        .header-divider {
            width: 1px;
            height: 24px;
            background: var(--border);
        }

        .header-meta { display: flex; flex-direction: column; gap: 2px; }

        .breadcrumb {
            font-size: 10px;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -0.02em;
            color: var(--text);
        }

        .page-title span { color: var(--accent); }

        /* ── Layout ── */
        .main-content {
            padding: 40px 48px;
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 28px;
        }

        /* ── Hero card ── */
        .hero-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 36px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 32px;
            position: relative;
            overflow: hidden;
        }

        .hero-card::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 220px; height: 220px;
            background: radial-gradient(circle, var(--accent-glow), transparent 70%);
            pointer-events: none;
        }

        .hero-left { display: flex; flex-direction: column; gap: 12px; }

        .placa-badge {
            display: inline-flex;
            align-items: center;
            background: var(--accent-dim);
            border: 1px solid rgba(232, 255, 71, 0.35);
            color: var(--accent);
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 0.1em;
            padding: 6px 16px;
            border-radius: 8px;
            width: fit-content;
        }

        .hero-brand {
            font-family: 'Syne', sans-serif;
            font-size: 38px;
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.05;
        }

        .hero-model {
            font-size: 14px;
            color: var(--text-muted);
            letter-spacing: 0.04em;
        }

        .hero-price {
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--accent);
        }

        .hero-price span {
            font-size: 14px;
            color: var(--text-muted);
            font-family: 'DM Mono', monospace;
            font-weight: 400;
        }

        .hero-actions { display: flex; gap: 10px; flex-shrink: 0; }

        /* ── Grid de secciones ── */
        .sections-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
            background: var(--surface2);
        }

        .section-icon {
            width: 30px; height: 30px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .icon-vehicle { background: var(--accent-dim); }
        .icon-owner   { background: var(--info-dim); }

        .section-title {
            font-family: 'Syne', sans-serif;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--text-dim);
        }

        .section-body { padding: 8px 0; }

        .field-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 24px;
            border-bottom: 1px solid rgba(42, 45, 53, 0.5);
            gap: 16px;
        }

        .field-row:last-child { border-bottom: none; }

        .field-label {
            font-size: 11px;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--text-muted);
            flex-shrink: 0;
        }

        .field-value {
            font-size: 13px;
            color: var(--text);
            text-align: right;
            word-break: break-all;
        }

        .field-value.accent {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            color: var(--accent);
        }

        .color-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--surface2);
            border: 1px solid var(--border);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
        }

        .color-dot {
            width: 9px; height: 9px;
            border-radius: 50%;
            background: var(--info);
            box-shadow: 0 0 6px var(--info);
            flex-shrink: 0;
        }

        /* ── Buttons ── */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 12px;
            letter-spacing: 0.04em;
            padding: 10px 18px;
            border-radius: 9px;
            border: 1px solid transparent;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
            white-space: nowrap;
        }

        .btn:hover { transform: translateY(-2px); }
        .btn:active { transform: translateY(0); }

        .btn-edit {
            background: rgba(167, 139, 250, 0.12);
            border-color: rgba(167, 139, 250, 0.3);
            color: var(--edit);
        }

        .btn-edit:hover { box-shadow: 0 6px 18px rgba(167, 139, 250, 0.2); }

        .btn-delete {
            background: var(--danger-dim);
            border-color: rgba(255, 77, 77, 0.3);
            color: var(--danger);
        }

        .btn-delete:hover { box-shadow: 0 6px 18px rgba(255, 77, 77, 0.2); }

        /* ── ID footer ── */
        .id-footer {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px 24px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            font-size: 11px;
            color: var(--text-muted);
        }

        .id-label {
            letter-spacing: 0.1em;
            text-transform: uppercase;
            flex-shrink: 0;
        }

        .id-value {
            color: var(--text-dim);
            font-size: 11px;
            word-break: break-all;
        }

        /* ── Responsive ── */
        @@media (max-width: 800px) {
            .page-header { padding: 18px 20px; }
            .main-content { padding: 24px 16px; }
            .hero-card { flex-direction: column; align-items: flex-start; }
            .hero-brand { font-size: 28px; }
            .sections-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="page-header">
        <a href="/Vehiculos" class="back-btn">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Volver
        </a>
        <div class="header-divider"></div>
        <div class="header-meta">
            <span class="breadcrumb">Vehículos / Detalle</span>
            <h1 class="page-title">Ficha del <span>Vehículo</span></h1>
        </div>
    </header>

    <main class="main-content">

        @if (Model.vehiculo == null)
        {
            <div style="text-align:center; padding: 80px 24px; color: var(--text-muted); border: 1px dashed var(--border); border-radius: 16px;">
                <div style="font-size:48px; margin-bottom:16px;">🔍</div>
                <p style="font-family:'Syne',sans-serif; font-size:18px; color:var(--text-dim);">Vehículo no encontrado</p>
            </div>
        }
        else
        {
            <!-- Hero -->
            <div class="hero-card">
                <div class="hero-left">
                    <span class="placa-badge">@Model.vehiculo.Placa</span>
                    <div class="hero-brand">@Model.vehiculo.Marca</div>
                    <div class="hero-model">@Model.vehiculo.Modelo &middot; @Model.vehiculo.Anio</div>
                    <div class="hero-price">
                        <span>₡ </span>@Model.vehiculo.Precio.ToString("N0")
                    </div>
                </div>
                <div class="hero-actions">
                    <a href="/Vehiculos/Editar/@Model.vehiculo.Id" class="btn btn-edit">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                            <path d="M9 1.5a1.5 1.5 0 0 1 2.12 2.12L4.25 10.5l-3 .5.5-3Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                        </svg>
                        Editar
                    </a>
                    <a href="/Vehiculos/Eliminar/@Model.vehiculo.Id" class="btn btn-delete">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                            <path d="M2 3.5h9M5 3.5V2.5h3v1M3.5 3.5l.5 7h5l.5-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Eliminar
                    </a>
                </div>
            </div>

            <!-- Secciones -->
            <div class="sections-grid">

                <!-- Info del vehículo -->
                <div class="section-card">
                    <div class="section-header">
                        <div class="section-icon icon-vehicle">🚗</div>
                        <span class="section-title">Información del vehículo</span>
                    </div>
                    <div class="section-body">
                        <div class="field-row">
                            <span class="field-label">Placa</span>
                            <span class="field-value accent">@Model.vehiculo.Placa</span>
                        </div>
                        <div class="field-row">
                            <span class="field-label">Marca</span>
                            <span class="field-value">@Model.vehiculo.Marca</span>
                        </div>
                        <div class="field-row">
                            <span class="field-label">Modelo</span>
                            <span class="field-value">@Model.vehiculo.Modelo</span>
                        </div>
                        <div class="field-row">
                            <span class="field-label">Año</span>
                            <span class="field-value">@Model.vehiculo.Anio</span>
                        </div>
                        <div class="field-row">
                            <span class="field-label">Color</span>
                            <span class="field-value">
                                <span class="color-pill">
                                    <span class="color-dot"></span>
                                    @Model.vehiculo.Color
                                </span>
                            </span>
                        </div>
                        <div class="field-row">
                            <span class="field-label">Precio</span>
                            <span class="field-value accent">₡ @Model.vehiculo.Precio.ToString("N0")</span>
                        </div>
                    </div>
                </div>

                <!-- Info del propietario -->
                <div class="section-card">
                    <div class="section-header">
                        <div class="section-icon icon-owner">👤</div>
                        <span class="section-title">Información del propietario</span>
                    </div>
                    <div class="section-body">
                        <div class="field-row">
                            <span class="field-label">Correo</span>
                            <span class="field-value">@Model.vehiculo.CorreoPropietario</span>
                        </div>
                        <div class="field-row">
                            <span class="field-label">Teléfono</span>
                            <span class="field-value">@Model.vehiculo.TelefonoPropietario</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ID del registro -->
            <div class="id-footer">
                <span class="id-label">ID Registro</span>
                <span class="id-value">@Model.vehiculo.Id</span>
            </div>
        }

    </main>

</body>
</html>
